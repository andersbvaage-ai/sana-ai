# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── AWS Bedrock (eu-north-1) ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
AWS_BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-6

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_MODE=symmetric
JWT_SECRET=
JWT_ISSUER=https://mock-epj.sana-ai.local
JWT_AUDIENCE=sana-ai-integration

# ── Brukere (JSON-array med bcrypt-hasher) ────────────────────────────────────
USERS_JSON=

# ── Revisjonslogg ─────────────────────────────────────────────────────────────
AUDIT_BACKEND=file
AUDIT_LOG_PATH=./audit.jsonl

# ── Kill-switch ───────────────────────────────────────────────────────────────
KILL_SWITCH_ENABLED=false
KILL_SWITCH_ADMIN_TOKEN=

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=30
RATE_LIMIT_BURST=10

# ── Mock ──────────────────────────────────────────────────────────────────────
MOCK_USE_REAL_AI=false
